  end
_G.package.preload['workshop.formats.lua.quote_string.custom_quotes'] =
  function(...)
    return
      {
        ['\x07'] = [[\a]],
        ['\x08'] = [[\b]],
        ['\x09'] = [[\t]],
        ['\x0a'] = [[\n]],
        ['\x0b'] = [[\v]],
        ['\x0c'] = [[\f]],
        ['\x0d'] = [[\r]],
        ['"'] = [[\"]],
        ["'"] = [[\']],
        ['\\'] = [[\\]],
      }
  end
