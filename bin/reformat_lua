_G.package.preload[
  'workshop.formats.lua.formatter.handlers.statements.blocks.generic_for_block'
] =
  function(...)
    local header_oneline =
      function(self, node)
        local printer = self.printer
        printer:add_curline('for ')
        if not self:process_node(node.names) then
          return
        end
        printer:add_curline(' in ')
        if not self:process_node(node.expr_list) then
          return
        end
        printer:add_curline(' do')
        return true
      end
    local in_part_oneline =
      function(self, node)
        self.printer:add_curline(' in ')
        return self:process_node(node.expr_list)
      end
    local in_part_multiline =
      function(self, node)
        self.printer:add_textline(' in')
        self.printer:request_clean_line()
        return self:process_block(node.expr_list)
      end
    local header_multiline =
      function(self, node)
        local printer = self.printer
        printer:add_curline('for')
        printer:request_clean_line()
        printer:inc_indent()
        if not self:process_node(node.names) then
          return
        end
        if not self:variate(node, in_part_oneline, in_part_multiline) then
          return
        end
        printer:dec_indent()
        printer:request_clean_line()
        printer:add_curline('do')
        return true
      end
    local multiliner =
      function(self, node)
        local printer = self.printer
        printer:request_clean_line()
        if not self:variate(node, header_oneline, header_multiline) then
          return
        end
        printer:request_clean_line()
        if not self:process_block(node.body) then
          return
        end
        printer:request_clean_line()
        printer:add_curline('end')
        return true
      end
    return
      function(self, node)
        return self:variate(node, nil, multiliner)
      end
  end
_G.package.preload['workshop.formats.lua.formatter.handlers.statements.blocks.do_block'] =
  function(...)
    return
      function(self, node)
        self.printer:request_clean_line()
        return self:process_block_multiline('do', node[1], 'end')
      end
  end
_G.package.preload['workshop.formats.lua.formatter.handlers.expressions.table'] =
  function(...)
    local oneliner =
      function(self, node)
        local printer = self.printer
        printer:add_curline('{')
        for i = 1, #node do
          if (i > 1) then
            printer:add_curline(', ')
          end
          local key, value = node[i].key, node[i].value
          if key then
            if not self:process_node(key) then
              return
            end
            printer:add_curline(' = ')
          end
          if not self:process_node(value) then
            return
          end
        end
        printer:add_curline('}')
        return true
      end
    local multiliner =
      function(self, node)
        local printer = self.printer
        printer:request_clean_line()
        printer:add_curline('{')
        printer:inc_indent()
        for i = 1, #node do
          printer:request_clean_line()
          local key, value = node[i].key, node[i].value
          if key then
            if not self:process_node(key) then
              return
            end
            printer:add_curline(' = ')
            if not self:process_block(value) then
              return
            end
            printer:add_textline(',')
          else
            if not self:process_node(value) then
              return
            end
            printer:add_textline(',')
          end
        end
        printer:dec_indent()
        printer:request_clean_line()
        printer:add_curline('}')
        return true
      end
    return
      function(self, node)
        if (#node == 0) then
          self.printer:add_curline('{}')
          return true
        else
          return self:variate(node, oneliner, multiliner)
        end
      end
  end
