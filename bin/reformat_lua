_G.package.preload['workshop.formats.lua.ast_transformer.handlers.named_function'] =
  function(...)
    return
      function(self, node)
        node.dotted_name = node[1]
        node[1] = nil
        local seek_pos = 2
        if (node[seek_pos].type == 'colon_name') then
