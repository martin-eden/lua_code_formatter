  function(...)
    return
      function(self, s)
        if (self.num_line_feeds > 0) and (s ~= '') then
          self:store_textline()
        end
        if (self.line_with_text.text == '') then
          self.line_with_text.indent = self.next_line_indent
        end
        self.line_with_text:add(s)
      end
  end
